# Kamal secrets — loaded automatically on deploy.
# Copy to .kamal/secrets and fill in values.
# This file should NOT be committed (it's in .gitignore).

# Docker registry (ghcr.io)
KAMAL_REGISTRY_USERNAME=your-github-username
KAMAL_REGISTRY_PASSWORD=ghp_your_github_token

# Server
DEPLOY_HOST=your.server.ip
DEPLOY_DOMAIN=sybil.yourdomain.com

# App secrets (optional)
SYBIL_SEED_MARKETS=
