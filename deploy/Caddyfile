{
    email val@sybil.exchange
}

(ops_auth) {
    basic_auth {
        {$CADDY_OPS_AUTH_USER} {$CADDY_OPS_AUTH_HASH}
    }
}

172-104-31-54.nip.io {
    encode zstd gzip

    # SSE and WebSocket block streams: no timeout, flush immediately
    @streaming path /v1/blocks/stream
    reverse_proxy @streaming sybil-api:3000 {
        flush_interval -1
        transport http {
            read_timeout  0
            write_timeout 0
        }
    }

    reverse_proxy sybil-api:3000 {
        transport http {
            # Generous timeouts for order submission / LP solve under load
            dial_timeout    5s
            read_timeout    30s
            write_timeout   30s
        }
        health_uri      /v1/health
        health_interval 10s
        health_timeout  3s
        health_status   200
    }
}

