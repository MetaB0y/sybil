{
    email val@sybil.exchange
}

(ops_auth) {
    basic_auth {
        {$CADDY_OPS_AUTH_USER} {$CADDY_OPS_AUTH_HASH}
    }
}

{$SYBIL_API_SITE:https://api.sybil.exchange} {
    encode zstd gzip

    # WebSocket block streams: no upstream timeout.
    @streaming path /v1/blocks/ws /v2/blocks/ws
    reverse_proxy @streaming sybil-api:3000 {
        flush_interval -1
        transport http {
            read_timeout  0
            write_timeout 0
        }
    }

    reverse_proxy sybil-api:3000 {
        transport http {
            # Generous timeouts for order submission / LP solve under load
            dial_timeout    5s
            read_timeout    30s
            write_timeout   30s
        }
        health_uri      /v1/health
        health_interval 10s
        health_timeout  3s
        health_status   200
    }
}

# Public-facing Next.js web app. Kept on its own hostname so the trading API
# stays at the root domain (which is what NEXT_PUBLIC_API_BASE / NEXT_PUBLIC_WS_BASE
# are baked to point at). Caddy auto-provisions TLS for this name too.
# For a real product domain, Valery can instead make the apex serve the app and
# move the API to api.<domain> (rebuild sybil-web with the new NEXT_PUBLIC_* args).
{$SYBIL_APP_SITE:https://app.sybil.exchange} {
    encode zstd gzip
    reverse_proxy sybil-web:3000
}

{$SYBIL_ARENA_SITE:https://arena.62-171-170-238.nip.io} {
    encode zstd gzip

    import ops_auth
    reverse_proxy sybil-arena-dashboard:8501
}

{$SYBIL_GRAFANA_SITE:https://grafana.62-171-170-238.nip.io} {
