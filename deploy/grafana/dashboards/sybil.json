{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Block Height",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "sybil_block_height", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      }
    },
    {
      "title": "Blocks Produced",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "sybil_blocks_produced", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "steps": [{ "color": "blue", "value": null }] } },
        "overrides": []
      }
    },
    {
      "title": "Welfare (nanos)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "sybil_welfare_nanos", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "steps": [{ "color": "purple", "value": null }] } },
        "overrides": []
      }
    },
    {
      "title": "Volume (nanos)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "sybil_volume_nanos", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "steps": [{ "color": "orange", "value": null }] } },
        "overrides": []
      }
    },
    {
      "title": "Pending Bundles",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "sybil_pending_bundles", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "steps": [{ "color": "yellow", "value": null }, { "color": "red", "value": 1000 }] } },
        "overrides": []
      }
    },
    {
      "title": "Pending Orders",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "sybil_pending_orders", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 5000 }] } },
        "overrides": []
      }
    },
    {
      "title": "Order Flow per Block",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "rate(sybil_batch_orders_per_block_sum[1m]) / rate(sybil_batch_orders_per_block_count[1m])", "legendFormat": "batch orders", "refId": "A" },
        { "expr": "rate(sybil_fresh_orders_per_block_sum[1m]) / rate(sybil_fresh_orders_per_block_count[1m])", "legendFormat": "fresh orders", "refId": "B" },
        { "expr": "rate(sybil_carried_resting_orders_per_block_sum[1m]) / rate(sybil_carried_resting_orders_per_block_count[1m])", "legendFormat": "carried resting", "refId": "C" },
        { "expr": "rate(sybil_fresh_accepted_orders_per_block_sum[1m]) / rate(sybil_fresh_accepted_orders_per_block_count[1m])", "legendFormat": "fresh accepted", "refId": "D" },
        { "expr": "rate(sybil_rejections_per_block_sum[1m]) / rate(sybil_rejections_per_block_count[1m])", "legendFormat": "rejections", "refId": "E" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "title": "Fills per Block",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "rate(sybil_fills_per_block_sum[1m]) / rate(sybil_fills_per_block_count[1m])", "legendFormat": "avg fills/block", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "title": "Solve Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sequencer:solve_time_seconds:avg5m", "legendFormat": "avg solve time", "refId": "A" },
        { "expr": "sequencer:solve_time_seconds:p99", "legendFormat": "p99", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sum(rate(sybil_http_requests_total[1m])) by (path)", "legendFormat": "{{path}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } } }, "overrides": [] }
    },
    {
      "title": "HTTP Latency by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sybil_http_request_duration_seconds{quantile=\"0.95\"}", "legendFormat": "p95 {{method}} {{path}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line" } }, "overrides": [] }
    },
    {
      "title": "Submission Outcomes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sum(rate(sybil_order_submissions_total[5m])) by (source, result)", "legendFormat": "{{source}} {{result}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 15 } }, "overrides": [] }
    },
    {
      "title": "Orders Received Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sum(rate(sybil_orders_received_total[5m])) by (source, result)", "legendFormat": "{{source}} {{result}}", "refId": "A" },
        { "expr": "sum(rate(sybil_order_cancels_total[5m])) by (source, result)", "legendFormat": "cancel {{source}} {{result}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 15 } }, "overrides": [] }
    },
    {
      "title": "Block Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "rate(sybil_blocks_produced[1m])", "refId": "A" }],
      "options": { "graphMode": "area" },
      "fieldConfig": {
        "defaults": { "unit": "cps", "thresholds": { "steps": [{ "color": "blue", "value": null }] } },
        "overrides": []
      }
    },
    {
      "title": "Rejection Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{
        "expr": "sum(rate(sybil_order_submissions_total{result=\"rejected\"}[5m])) / clamp_min(sum(rate(sybil_order_submissions_total[5m])), 0.0001)",
        "refId": "A"
      }],
      "options": { "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 0.25 },
            { "color": "red", "value": 0.5 }
          ] }
        },
        "overrides": []
      }
    },
    {
      "title": "Orders Filled (ratio)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{
        "expr": "rate(sybil_fills_per_block_sum[5m]) / clamp_min(rate(sybil_orders_per_block_sum[5m]), 0.0001)",
        "refId": "A"
      }],
      "options": { "graphMode": "area" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "thresholds": { "steps": [{ "color": "purple", "value": null }] } },
        "overrides": []
      }
    },
    {
      "title": "Market Fills Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "sum(rate(sybil_market_fills_total[1m]))", "refId": "A" }],
      "options": { "graphMode": "area" },
      "fieldConfig": {
        "defaults": { "unit": "cps", "thresholds": { "steps": [{ "color": "teal", "value": null }] } },
        "overrides": []
      }
    },
    {
      "title": "Solve Time Quantiles",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "max(sybil_solve_time_seconds{quantile=\"0.5\"})", "legendFormat": "p50", "refId": "A" },
        { "expr": "max(sybil_solve_time_seconds{quantile=\"0.95\"})", "legendFormat": "p95", "refId": "B" },
        { "expr": "sequencer:solve_time_seconds:p99", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 0.1 }
          ] }
        },
        "overrides": []
      }
    },
    {
      "title": "Per-Market Volume (cumulative)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sybil_market_volume_nanos{market_id=~\"$market\"}", "legendFormat": "market {{market_id}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "none" } } },
        "overrides": []
      }
    },
    {
      "title": "Per-Market Clearing Price (outcome 0)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sybil_market_clearing_price_nanos{market_id=~\"$market\", outcome=\"0\"}", "legendFormat": "market {{market_id}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "custom": { "drawStyle": "line", "fillOpacity": 5 } },
        "overrides": []
      }
    },
    {
      "title": "Per-Market Fills Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sum by (market_id) (rate(sybil_market_fills_total{market_id=~\"$market\"}[1m]))", "legendFormat": "market {{market_id}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "cps", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } },
        "overrides": []
      }
    },
    {
      "title": "Actor Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sybil_actor_queue_depth", "legendFormat": "{{actor}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1000 },
            { "color": "red", "value": 5000 }
          ] }
        },
        "overrides": []
      }
    },
    {
      "title": "Prover Latest Height",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 64 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "sybil_prover_latest_prepared_height", "refId": "A" }],
      "options": { "graphMode": "area" },
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } },
        "overrides": []
      }
    },
    {
      "title": "Prover Lag",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 64 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "max(sybil_block_height) - max(sybil_prover_latest_prepared_height)", "refId": "A" }],
      "options": { "graphMode": "area" },
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "orange", "value": 5 },
          { "color": "red", "value": 10 }
        ] } },
        "overrides": []
      }
    },
    {
      "title": "Prover Jobs Queued",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 64 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "sybil_prover_jobs_queued", "refId": "A" }],
      "options": { "graphMode": "area" },
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "orange", "value": 10 },
          { "color": "red", "value": 20 }
        ] } },
        "overrides": []
      }
    },
    {
      "title": "Prover Artifact Age",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 64 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "sybil_prover_latest_artifact_age_seconds", "refId": "A" }],
      "options": { "graphMode": "area" },
      "fieldConfig": {
        "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "orange", "value": 180 },
          { "color": "red", "value": 300 }
        ] } },
        "overrides": []
      }
    },
    {
      "title": "Prover Artifacts by Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 68 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sybil_prover_artifacts_total", "legendFormat": "{{status}} {{proof_status}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "title": "Prover Lag and Queue",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 68 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "max(sybil_block_height) - max(sybil_prover_latest_prepared_height)", "legendFormat": "block lag", "refId": "A" },
        { "expr": "sybil_prover_jobs_queued", "legendFormat": "queued jobs", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "title": "Market Coverage",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 76 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sybil_markets_active_total", "legendFormat": "active", "refId": "A" },
        { "expr": "sybil_markets_priced_total", "legendFormat": "priced", "refId": "B" },
        { "expr": "sybil_markets_with_volume_total", "legendFormat": "with volume", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      }
    },
    {
      "title": "Live Reference Prices",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 76 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sybil_reference_prices_active_total", "legendFormat": "active references", "refId": "A" },
        { "expr": "sybil_price_reference_pairs_total", "legendFormat": "priced pairs", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [
          { "color": "red", "value": null },
          { "color": "green", "value": 1 }
        ] } },
        "overrides": []
      }
    },
    {
      "title": "Reference Price Age",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 76 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "sybil_reference_prices_age_seconds", "refId": "A" }],
      "options": { "graphMode": "area" },
      "fieldConfig": {
        "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "orange", "value": 120 },
          { "color": "red", "value": 180 }
        ] } },
        "overrides": []
      }
    },
    {
      "title": "Price Divergence",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 76 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sybil_price_reference_avg_abs_diff_nanos / 1000000000", "legendFormat": "avg", "refId": "A" },
        { "expr": "sybil_price_reference_max_abs_diff_nanos / 1000000000", "legendFormat": "max", "refId": "B" }
      ],
      "options": { "graphMode": "area" },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "orange", "value": 0.025 },
          { "color": "red", "value": 0.05 }
        ] } },
        "overrides": []
      }
    },
    {
      "title": "Demo Activity Window",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 80 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sum(increase(sybil_order_submissions_total[15m]))", "legendFormat": "submissions 15m", "refId": "A" },
        { "expr": "sum(increase(sybil_market_fills_total[15m]))", "legendFormat": "fills 15m", "refId": "B" },
        { "expr": "count(increase(sybil_market_fills_total[15m]) > 0)", "legendFormat": "markets filled 15m", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "thresholds": { "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      }
    },
    {
      "title": "Bot Orders and Fills",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 80 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sybil_bot_total_orders", "legendFormat": "orders {{trader}}", "refId": "A" },
        { "expr": "sybil_bot_total_fills", "legendFormat": "fills {{trader}}", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "title": "qMDB Root Verification",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 84 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "increase(sybil_store_commit_root_verified_total[5m])", "legendFormat": "verified commits", "refId": "A" },
        { "expr": "increase(sybil_store_qmdb_root_mismatch_total[5m])", "legendFormat": "mismatches", "refId": "B" },
        { "expr": "increase(sybil_store_qmdb_repair_total[5m])", "legendFormat": "repairs {{result}}", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "custom": { "drawStyle": "bars", "fillOpacity": 50 }, "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "red", "value": 1 }
        ] } },
        "overrides": []
      }
    },
    {
      "title": "Resources and Memory Attribution",
      "type": "row",
