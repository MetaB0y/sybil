ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# live.runner reads this from the environment; do not pass it as a CLI arg.
OPENROUTER_API_KEY=sk-or-v1-...
# Optional live arena market selection. Defaults are ARENA_MARKET_PROFILE=all
# and ARENA_MAX_MARKETS=0, which preserve broad automatic discovery.
# ARENA_MARKET_PROFILE=important-news
# ARENA_MAX_MARKETS=64
# Optional concurrent Stage 1 A/B experiment. Set both or neither; use a new id
# for every process start/genesis and freeze an explicit comma-separated cohort.
# ARENA_STAGE1_AB_EXPERIMENT_ID=stage1-2026-07-12-a
# ARENA_MARKET_IDS=17,29,44
# Optional outcome polling cadence for an active experiment (default: 900s).
# Dormant env values are ignored when the experiment id is unset.
# ARENA_OUTCOME_RECORD_INTERVAL_S=900
SYBIL_API_URL=http://localhost:3001

# Actor Liquidity v2: the same JSON file consumed by sybil-api. It must contain
# exactly one market_maker and fifteen noise entries with durable account ids and
# unique >=32-byte bearer tokens. The live runner filters the fifteen noise rows.
# SYBIL_NOISE_ACTORS_JSON=/run/secrets/sybil-actor-credentials.json
# ARENA_NOISE_MIN_ORDER_DOLLARS=7
# ARENA_NOISE_MAX_ORDER_DOLLARS=150
# ARENA_NOISE_INVENTORY_BIAS_DOLLARS=800
# ARENA_NOISE_CROSSING_EDGE=0.035
