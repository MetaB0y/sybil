ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# live.runner reads this from the environment; do not pass it as a CLI arg.
OPENROUTER_API_KEY=sk-or-v1-...
# Optional live arena market selection. Defaults are ARENA_MARKET_PROFILE=all
# and ARENA_MAX_MARKETS=0, which preserve broad automatic discovery.
# ARENA_MARKET_PROFILE=important-news
# ARENA_MAX_MARKETS=64
# Optional concurrent Stage 1 A/B experiment. Set both or neither; use a new id
# for every process start/genesis and freeze an explicit comma-separated cohort.
# ARENA_STAGE1_AB_EXPERIMENT_ID=stage1-2026-07-12-a
# ARENA_MARKET_IDS=17,29,44
SYBIL_API_URL=http://localhost:3001
