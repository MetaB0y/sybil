{
  "schema_version": 2,
  "protocol_id": "solver-evaluation-v2-retained-cash",
  "title": "Certified retained-cash clearing under genuine shared-capital stress",
  "analysis_policy": {
    "freeze_policy": "protocol and implementation are committed before the full run; results are committed separately",
    "primary_unit": "one declared order book, budget ratio, and solver",
    "budget_definition": "for lp_limit_value experiments, B_k is the declared multiplier times MM k's correctly scaled buy/sell-reduced limit-value in the unconstrained LP allocation",
    "primary_objective": "shifted retained-cash objective in nanodollars, evaluated on every landed allocation",
    "primary_certificate": "generalized Frank-Wolfe gap for the continuous retained-cash allocation",
    "protocol_welfare": "integer verifier-recomputed net welfare with signed complete-set mint/burn cost",
    "failure_policy": "retain every panic, empty result, backend error, timeout, iteration cap, and verifier-invalid allocation",
    "baseline_policy": "lp-unconstrained is intentionally allowed to violate MM budgets and is never relabelled protocol-feasible",
    "negative_control": "budgets at and above unconstrained LP limit-value test exact LP recovery",
    "selection_policy": "all seed ranges, budget ratios, solvers, metrics, and plots are declared before the full run; no post-hoc seed filtering",
    "tuning_policy": "development used seeds below 30000; untouched evaluation seeds begin at 50000 and are not used for algorithm tuning",
    "missing_policy": "no invented quality or runtime values for failed runs; denominators remain declared counts"
  },
  "warmup": {
    "profile": "flash-ladder",
    "scale": "flash-reference",
    "seed": 17,
    "budget_scale": 1.0
  },
  "solvers": {
    "lp-unconstrained": {
      "kind": "lp-unconstrained",
      "label": "LP without MM budgets (infeasible baseline)",
      "fallback_to_lp": false
    },
    "lp": {
      "kind": "lp",
      "label": "Production LP-SLP plus visible landing trim",
      "max_iterations": 5,
      "fallback_to_lp": false
    },
    "retained-cash-fw": {
      "kind": "retained-cash-fw",
      "label": "Certified retained-cash generalized Frank-Wolfe",
      "max_iterations": 100,
      "tolerance": 0.00001,
      "absolute_tolerance": 1000000.0,
      "line_search_steps": 48,
      "fallback_to_lp": false
    },
    "conic-quasi": {
      "kind": "conic-quasi",
      "label": "Normalized Clarabel retained-cash reference",
      "max_iterations": 200,
      "tolerance": 0.00000001,
      "time_limit_seconds": 20.0,
      "fallback_to_lp": false
    },
    "conic-fisher": {
      "kind": "conic-fisher",
      "label": "Normalized no-cash Fisher ablation",
      "max_iterations": 200,
      "tolerance": 0.00000001,
      "time_limit_seconds": 20.0,
      "fallback_to_lp": false
    },
    "milp-exact": {
      "kind": "milp-exact",
      "label": "Correctly scaled exact hard-budget MIQCQP",
      "time_limit_seconds": 10.0,
      "gap_tolerance": 0.0,
      "fallback_to_lp": false
    }
  },
