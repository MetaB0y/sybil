{
  "schema_version": 2,
  "protocol_id": "solver-pacing-bundle-development-v2",
  "title": "Development-only pacing-bundle landing, welfare-tail, LP controls, corrected-conic, and orthogonal scaling stress",
  "analysis_policy": {
    "evidence_status": "development-only; never present these results as untouched or held-out evaluation",
    "primary_unit": "one declared order book, budget ratio, and solver",
    "budget_definition": "B_k is the declared multiplier times MM k's correctly scaled buy/sell-reduced limit-value in the unconstrained LP allocation",
    "primary_objective": "shifted retained-cash objective in nanodollars, evaluated on every landed allocation",
    "primary_certificate": "method-specific valid upper bound minus continuous retained-cash primal objective",
    "failure_policy": "retain every panic, empty result, backend error, timeout, iteration cap, and verifier-invalid allocation",
    "selection_policy": "run every declared seed, budget, all four feasible solvers plus the budget-blind LP negative control, every order-count scale, and every MM-count scale; no post-hoc book filtering",
    "tuning_policy": "all seeds are below 30000 and may inform implementation; a later paper claim requires a separately frozen implementation and untouched seed range",
    "missing_policy": "no invented quality or runtime values for failed runs; denominators remain declared counts",
    "scaling_policy": "vary order count at two MMs, then MM count at 2000 orders, so problem size and pacing dimension are not confounded"
  },
  "warmup": {
    "profile": "flash-ladder",
    "scale": "flash-reference",
    "seed": 17,
    "budget_scale": 1.0
  },
  "solvers": {
    "lp-unconstrained": {
      "kind": "lp-unconstrained",
      "label": "Budget-blind unconstrained LP negative control",
      "fallback_to_lp": false
    },
    "lp": {
      "kind": "lp",
      "label": "Five-step price-linearized LP-SLP baseline",
      "max_iterations": 5,
      "fallback_to_lp": false
    },
    "retained-cash-fw": {
      "kind": "retained-cash-fw",
      "label": "Certified retained-cash generalized Frank-Wolfe",
      "max_iterations": 100,
      "tolerance": 0.00001,
      "absolute_tolerance": 1000000.0,
      "line_search_steps": 48,
      "fallback_to_lp": false
    },
    "pacing-bundle": {
      "kind": "pacing-bundle",
      "label": "Certified fully corrective pacing bundle",
      "max_iterations": 100,
      "max_master_iterations": 1000,
      "tolerance": 0.00000001,
      "absolute_tolerance": 100000.0,
      "master_tolerance": 0.000000001,
      "master_absolute_tolerance": 1000.0,
      "line_search_steps": 48,
      "fallback_to_lp": false
    },
    "conic-quasi": {
      "kind": "conic-quasi",
      "label": "Corrected-epigraph Clarabel retained-cash reference",
      "max_iterations": 200,
      "tolerance": 0.00000001,
      "time_limit_seconds": 20.0,
      "fallback_to_lp": false
    }
  },
