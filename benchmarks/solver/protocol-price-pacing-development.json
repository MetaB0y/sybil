  "title": "Development-only direct price-pacing dual comparison",
  "analysis_policy": {
    "evidence_status": "development-only; implementation and protocol may change after observing every result",
    "primary_unit": "one declared order book, budget ratio, and solver",
    "primary_objective": "shifted retained-cash objective in nanodollars on landed fills",
    "primary_certificate": "method-specific continuous upper bound minus feasible continuous primal objective",
    "failure_policy": "retain every panic, backend error, cap, landing failure, and verifier-invalid result",
    "selection_policy": "run every declared solver on every declared market-like, shared-capital, numerical, and MM-dimension case",
    "tuning_policy": "all seeds are below 30000; freeze a later source and protocol before untouched evaluation",
    "scaling_policy": "keep order count fixed while varying MM dimension"
  },
