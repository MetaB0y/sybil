    "rc-structural": {
      "kind": "retained-cash-structural",
      "label": "Certified retained-cash FW with structural oracle",
      "max_iterations": 100,
      "tolerance": 0.00001,
      "absolute_tolerance": 1000000.0,
      "line_search_steps": 48,
      "fallback_to_lp": false
    },
    "bundle-structural": {
      "kind": "pacing-bundle-structural",
