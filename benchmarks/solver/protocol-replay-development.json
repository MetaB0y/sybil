{
  "schema_version": 3,
  "protocol_id": "solver-sequencer-replay-development-v2",
  "title": "Development-only multi-regime lifecycle solver replay",
  "analysis_policy": {
    "evidence_status": "development-only sequencer simulation; not real order flow or held-out evidence",
    "primary_unit": "one solver-boundary replay case, budget ratio, and solver",
    "hard_gates": "no panic, solver failure, timeout, or verifier-invalid landed result",
    "soft_metrics": "wall-time median and tails; retained-cash objective and welfare gaps; certificate and landing tails; allocation and price distance; MM utilization",
    "selection_policy": "prefer Pareto improvements; do not collapse quality, robustness, latency, and simplicity into one score",
    "corpus_policy": "cases preserve accepted-order sequence across standard, grouped-news, mid-resolution, and dense multi-batch sequencer lifecycles while omitting accounts, signatures, balances, names, and solver output"
  },
