{
  "schema_version": 1,
  "protocol_id": "solver-evaluation-v1",
  "title": "Sybil solver quality, robustness, and scaling evaluation",
  "analysis_policy": {
    "primary_unit": "one generated order book identified by experiment, budget scale, and seed",
    "primary_welfare": "integer verifier-recomputed net welfare after signed complete-set mint/burn cost",
    "runtime_statistic": "median wall time across books; no failed or invalid run is included as a timing success",
    "quality_reference": "production LP on the identical order book, reported as a reference rather than a proof of global optimality",
    "failure_policy": "retain and count every panic, empty result, solver error, timeout, and verifier-invalid result",
    "exclusion_policy": "no post-hoc run exclusion; the analysis consumes every JSONL record",
    "multiplicity_policy": "seed-level intervals describe variation across generated books, not repeated-measure timing noise",
    "interval_policy": "distribution summaries use medians and interquartile ranges; paired mean welfare-gap intervals use 10000 deterministic seed-level bootstrap resamples with RNG seed 20260713",
    "missing_policy": "failed and invalid runs are counted but are not assigned invented welfare or runtime-quality values; every table reports its denominator and success count"
  },
  "warmup": {
    "profile": "balanced",
    "scale": "reference",
    "seed": 7,
    "budget_scale": 1.0
  },
  "solvers": {
    "lp": {
      "kind": "lp",
      "label": "LP (production)",
      "max_iterations": 1,
      "fallback_to_lp": false
    },
    "iter-lp": {
      "kind": "iter-lp",
      "label": "IterLP fixed point",
      "max_iterations": 15,
      "tolerance": 0.0001,
      "damping": 0.6,
      "fallback_to_lp": false
    },
    "eg": {
      "kind": "eg",
      "label": "EG Frank-Wolfe",
      "max_iterations": 25,
      "tolerance": 0.000001,
      "q_tolerance": 1.0,
      "line_search_steps": 15,
      "fallback_to_lp": false
    },
    "conic-quasi": {
      "kind": "conic-quasi",
      "label": "Conic quasi-Fisher",
      "max_iterations": 200,
      "tolerance": 0.00000001,
      "time_limit_seconds": 30.0,
      "fallback_to_lp": false
    },
    "conic-fisher": {
      "kind": "conic-fisher",
      "label": "Conic Fisher (no retained cash)",
      "max_iterations": 200,
      "tolerance": 0.00000001,
      "time_limit_seconds": 30.0,
      "fallback_to_lp": false
    },
    "decomposed-lp": {
      "kind": "decomposed-lp",
      "label": "Decomposed LP",
      "max_iterations": 20,
      "tolerance": 0.0001,
      "fallback_to_lp": false
    },
    "decomposed-quasi": {
      "kind": "decomposed-quasi",
      "label": "Decomposed conic quasi-Fisher",
      "max_iterations": 20,
      "tolerance": 0.0001,
      "inner_max_iterations": 200,
      "inner_tolerance": 0.00000001,
      "time_limit_seconds": 30.0,
      "fallback_to_lp": false
    },
    "milp-exact": {
      "kind": "milp-exact",
      "label": "MILP exact-budget reference",
      "time_limit_seconds": 3.0,
      "gap_tolerance": 0.0,
      "fallback_to_lp": false
    }
  },
