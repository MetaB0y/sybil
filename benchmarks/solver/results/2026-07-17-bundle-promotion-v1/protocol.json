{
  "schema_version": 2,
  "protocol_id": "solver-bundle-promotion-evaluation-v1",
  "title": "Frozen retained-cash production-candidate evaluation",
  "analysis_policy": {
    "evidence_status": "untouched generated seeds frozen before evaluation; candidate algorithms and acceptance policy fixed on main at the protocol commit",
    "primary_unit": "one declared order book, budget ratio, and solver",
    "primary_objective": "shifted retained-cash objective in nanodollars, evaluated on every landed allocation",
    "hard_gates": "complete fingerprint-consistent matrix; no new panic, backend failure, timeout, empty result, verifier-invalid result, price-support regression, or MM-budget violation",
    "promotion_rule": "exact-component bundle must be at least as available as RC-FW, have no material paired retained-objective regression, and offer a credible broad Pareto improvement across certificate, landing, latency tails, and complexity",
    "failure_policy": "retain every panic, empty result, backend error, timeout, iteration cap, and verifier-invalid allocation",
    "seed_policy": "seeds 70000 through 71002 were not used by solver development and must be evaluated once against the frozen source revision",
    "scaling_policy": "separate random shape, observed-style generator, numerical range, budget pressure, order count, and pacing dimension; balanced component slices are explicit rather than assumed representative"
  },
  "warmup": {
    "profile": "flash-ladder",
    "scale": "flash-medium",
    "seed": 17,
    "budget_scale": 1.0
  },
  "solvers": {
