{
  "schema_version": 2,
  "protocol_id": "solver-structural-oracle-development-v1",
  "title": "Development-only structural price-sweep oracle comparison",
  "analysis_policy": {
    "evidence_status": "development-only; implementation and protocol may change after observing every result",
    "primary_unit": "one declared order book, budget ratio, and solver",
    "primary_objective": "shifted retained-cash objective in nanodollars on landed fills",
    "primary_certificate": "continuous upper bound minus feasible continuous primal objective",
    "failure_policy": "retain every panic, oracle recovery failure, cap, landing failure, and verifier-invalid result",
    "selection_policy": "compare identical retained-cash algorithms with HiGHS and structural price-sweep oracles on every declared market-like, flash, numerical-range, and MM-dimension case",
    "tuning_policy": "all seeds are development-only and below 30000; no result from this protocol is held-out evidence",
    "scaling_policy": "separate market/order-shape stress from MM-dimension stress"
  },
  "warmup": {
    "profile": "flash-ladder",
    "scale": "flash-medium",
    "seed": 20999,
    "budget_scale": 1.0
  },
  "solvers": {
    "rc-highs": {
      "kind": "retained-cash-fw",
      "label": "Retained-cash FW with HiGHS oracle",
      "max_iterations": 100,
      "tolerance": 0.00001,
      "absolute_tolerance": 1000000.0,
      "line_search_steps": 48,
      "fallback_to_lp": false
    },
    "rc-structural": {
      "kind": "retained-cash-structural",
      "label": "Retained-cash FW with structural price-sweep oracle",
      "max_iterations": 100,
      "tolerance": 0.00001,
      "absolute_tolerance": 1000000.0,
      "line_search_steps": 48,
      "fallback_to_lp": false
    },
    "bundle-highs": {
      "kind": "pacing-bundle",
      "label": "Pacing bundle with HiGHS oracle",
      "max_iterations": 100,
      "max_master_iterations": 1000,
      "tolerance": 0.00000001,
      "absolute_tolerance": 1000000.0,
      "master_tolerance": 0.000000001,
      "master_absolute_tolerance": 1000.0,
      "line_search_steps": 48,
      "fallback_to_lp": false
    },
    "bundle-structural": {
      "kind": "pacing-bundle-structural",
      "label": "Pacing bundle with structural price-sweep oracle",
      "max_iterations": 100,
      "max_master_iterations": 1000,
      "tolerance": 0.00000001,
