# The cargo-chef planner and Rust builder need only the root manifests and the
# complete Cargo workspace under crates/. Keep COPY . . manifest-driven without
# sending unrelated repository trees (some of which are several GB) to BuildKit.
**
!Cargo.toml
!Cargo.lock
!crates/
!crates/**
!tools/
!tools/**
!zk/
zk/*
!zk/openvm-guest/
zk/openvm-guest/*
!zk/openvm-guest/openvm/
zk/openvm-guest/openvm/*
!zk/openvm-guest/openvm/release/
zk/openvm-guest/openvm/release/*
!zk/openvm-guest/openvm/release/sybil-openvm-guest.commit.json

# Do not re-include generated artifacts nested inside an allowed crate.
crates/**/target/
crates/**/*.log
