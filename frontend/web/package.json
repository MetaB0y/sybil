{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "tokens:sync": "node scripts/sync-tokens.mjs",
    "types:generate": "bash scripts/generate-types.sh",
    "types:check": "bash scripts/generate-types.sh --check",
    "scenarios:check": "node scripts/check-computer-use-scenarios.mjs",
    "scenarios:list": "node scripts/check-computer-use-scenarios.mjs --list",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "SYBIL_SMOKE=1 vitest run scripts/smoke-signed-flow.test.ts --reporter=verbose",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.100.9",
    "borsh": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.10",
    "radix-ui": "^1.4.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.75.0",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@noble/curves": "^2.2.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "tailwindcss": "4.3.2",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
